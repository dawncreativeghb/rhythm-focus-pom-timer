{
  "manifest_version": 3,
  "name": "Rhythm Focus — Pomodoro",
  "version": "1.0.0",
  "description": "Minimalist Pomodoro timer in your browser. 25m focus, 5m breaks, long break after 4 sessions.",
  "permissions": ["storage", "alarms", "notifications"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "background": { "service_worker": "background.js" },
  "icons": { "48": "icon.png", "128": "icon.png" }
}
