{
  "name": "rhythm-focus-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Rhythm Focus desktop widget — always-on-top timer for Mac, Windows, and Linux.",
  "main": "main.cjs",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win"
  },
  "build": {
    "appId": "com.dawncreative.rhythmfocus.desktop",
    "productName": "Rhythm Focus",
    "files": [
      "main.cjs",
      "package.json"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity",
      "identity": null,
      "icon": "build/icon.png"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.png"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "devDependencies": {
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3"
  }
}
